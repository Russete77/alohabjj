# Copie para .env e preencha. .env NUNCA é commitado (ver .gitignore).

# Chave da API do Claude (billing externo). Necessária para etapas 3-4 (voz + dossiês).
ANTHROPIC_API_KEY=

# Teto de gasto por run, em USD. lib/claude.py aborta se ultrapassar.
SPEND_CAP_USD=10

# Fonte do backfill (etapa 2 — não precisa de chave).
ALOHA_BASE_URL=https://alohabjjnews.com

# Geração de imagem COMPLEXA (arte/hero dos carrosséis). "Quem estiver disponível faz".
# Ordem de preferência do fallback; o primeiro com chave é usado.
IMAGE_PROVIDER_ORDER=gemini,openai,runway
# GEMINI_API_KEY=          # Google Gemini/Imagen (pip install google-genai)
# OPENAI_API_KEY=          # OpenAI gpt-image (pip install openai)
# RUNWAYML_API_SECRET=     # Runway gen-4 imagem + vídeo/short-form (pip install runwayml)

# --- Futuro (fatias seguintes) ---
# Embeddings hospedados para dedupe (Voyage recomendado; ou OpenAI).
# VOYAGE_API_KEY=
